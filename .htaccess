<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Forçar HTTPS (Redireciona HTTP para HTTPS - 301)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2) Padronizar www (Redirecionar www para não-www - 301)
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# 3) Página 404 personalizada (força retorno à home page)
ErrorDocument 404 /index.html

# 4) Compressão gzip/deflate para performance (HTML, CSS, JS, SVG, JSON)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# 5) Cache de Navegador (Regras de Cache-Busting)
<IfModule mod_expires.c>
    ExpiresActive On

    # Imagens e Mídias (jpg, png, webp, svg): 1 mês
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"

    # CSS e JS: 1 semana
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"

    # HTML: 0 segundos
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Forçar ausência real de cache em HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </FilesMatch>
</IfModule>
